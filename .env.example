# === Database ===
DATABASE_URL=postgresql://oddsradar:oddsradar@localhost:5432/oddsradar

# === Auth.js ===
AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3040
ALLOWED_EMAILS=luca.cozza@gmail.com

# === Redis (BullMQ) ===
REDIS_URL=redis://127.0.0.1:6379

# === Ingestion sources ===
THE_ODDS_API_KEY=
# Comma-separated pool (preferito). Rotazione automatica quando una chiave esaurisce.
THE_ODDS_API_KEYS=
RAPIDAPI_KEY=
AF_SEASON=2025
BETFAIR_APP_KEY=
BETFAIR_USERNAME=
BETFAIR_PASSWORD=

# === Notifications ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
RESEND_API_KEY=

# === Scraper proxy pool (Sprint 2) ===
PROXY_PROVIDER=iproyal
PROXY_USER=
PROXY_PASS=
PROXY_HOST=
PROXY_PORT=
PROXY_MONTHLY_GB_LIMIT=25

# === Detection thresholds (tunable) ===
VALUE_EDGE_MIN=0.03
STEAM_WINDOW_MIN=5
STEAM_MOVE_PCT=8
ARB_EDGE_MIN=0.005

# === App ===
NODE_ENV=development
PORT=3041
